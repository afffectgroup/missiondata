# ============================================================
# MISSION DATA — Variables d'environnement
# Copie ce fichier en .env.local pour le dev local
# Dans Vercel : Settings → Environment Variables
# ============================================================

# --- Supabase (obligatoires) ---
# Récupère ces valeurs dans Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- APIs externes (obligatoires) ---
# Icypeas : https://app.icypeas.com → Settings → API
ICYPEAS_API_KEY=ton_api_key_icypeas

# Claude AI (pour mirroring + séquences)
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Optionnel ---
# Apify (si tu utilises le scraping LinkedIn en plus d'Icypeas)
# APIFY_API_TOKEN=apify_api_...
